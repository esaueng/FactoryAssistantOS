# Pinned upstream sources for Factory Assistant OS builds.
#
# Bump these deliberately: after changing a pin, run
#   make distclean bootstrap overlay
# and re-verify the rebrand checklist in docs/OS_BUILD.md against the new tag
# (upstream file layout moves between releases).
#
# The refs below are placeholders pinned at scaffold time — check
# https://github.com/home-assistant/operating-system/releases and update to
# the latest stable release before the first real build.

UPSTREAM_OS_REPO="https://github.com/home-assistant/operating-system.git"
UPSTREAM_OS_REF="16.2"

# Referenced by docs and Phase 2 fork work (not cloned by scripts/bootstrap.sh):
UPSTREAM_CORE_REPO="https://github.com/home-assistant/core.git"
UPSTREAM_SUPERVISOR_REPO="https://github.com/home-assistant/supervisor.git"
UPSTREAM_FRONTEND_REPO="https://github.com/home-assistant/frontend.git"
UPSTREAM_ADDONS_REPO="https://github.com/home-assistant/addons.git"
UPSTREAM_OS_AGENT_REPO="https://github.com/home-assistant/os-agent.git"
UPSTREAM_BUILDER_REPO="https://github.com/home-assistant/builder.git"
UPSTREAM_VERSION_REPO="https://github.com/home-assistant/version.git"
UPSTREAM_LANDINGPAGE_REPO="https://github.com/home-assistant/landingpage.git"
