# Factory Assistant OS defconfig fragment.
#
# Appended to the upstream generic_x86_64_defconfig by
# scripts/apply-overlay.sh. In kconfig defconfig processing the LAST
# assignment of a symbol wins, so these override the upstream values.
#
# Keep the values below in sync with branding/identity.env.
BR2_TARGET_GENERIC_HOSTNAME="factory-assistant"
BR2_TARGET_GENERIC_ISSUE="Factory Assistant OS - industrial monitoring appliance. Factory Assistant is based on Home Assistant."
