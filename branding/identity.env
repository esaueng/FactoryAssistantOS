# Factory Assistant product identity — single source of truth.
#
# scripts/apply-overlay.sh reads this file and writes the values into the
# upstream build tree (keeping upstream-internal variable NAMES intact for
# mergeability — see AGENTS.md invariant 4).
#
# Keep buildroot-external/configs/factory-assistant.config in sync with
# FAOS_HOSTNAME and FAOS_ISSUE.

FAOS_NAME="Factory Assistant OS"
FAOS_ID="faos"
FAOS_HOSTNAME="factory-assistant"
FAOS_ISSUE="Factory Assistant OS - industrial monitoring appliance (based on Home Assistant)"

# ---------------------------------------------------------------------------
# Go-live values (settled). org = esaueng. These are now REAL, not placeholders
# (docs/BRANDING.md §2, docs/OS_BUILD.md §4/§5):
#   1. Registry:  GitHub Container Registry under the esaueng org (ghcr.io/esaueng).
#   2. Channel:   stable.json served from the GitHub Pages site of
#                 esaueng/FactoryAssistant. GitHub Pages MUST be enabled for
#                 that repo and MUST serve stable.json at the URL below
#                 (and apparmor_stable.txt if the Supervisor's AppArmor
#                 profile updates are used).
#   3. OTA:       signed RAUC bundles (.raucb) ride GitHub Releases of
#                 esaueng/FactoryAssistant.
# OTA additionally requires Factory Assistant RAUC signing keys (OS_BUILD §5)
# before shipping updates.
# ---------------------------------------------------------------------------
FAOS_CONTAINER_REGISTRY="ghcr.io/esaueng"
FAOS_VERSION_CHANNEL_URL="https://esaueng.github.io/FactoryAssistant/stable.json"
FAOS_OTA_URL_TEMPLATE="https://github.com/esaueng/FactoryAssistant/releases/download/{version}/faos_{board}-{version}.raucb"
